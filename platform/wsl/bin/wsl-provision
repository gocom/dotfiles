#!/usr/bin/env bash

app_name="${0##*/}"
app_version="0.0.0"
DEFAULT_TIMEZONE="${DEFAULT_TIMEZONE:-Europe/Helsinki}"
DEFAULT_LOCALE="${DEFAULT_LOCALE:-en_GB.UTF-8}"

usage () {
  cat <<EOF
Provisions new Ubuntu based WSL image.

Runs similar provision steps as Windows Store does. This can be used when
installing custom WSL distribution. This command should be ran as root
within a WSL image to provision it.

Usage:
  $ $app_name

Options:
  -h, --help     Print this message
  -v, --version  Print version number

Example:
  $ $app_name
EOF
}

fatal () {
  echo "$1" >&2
  exit 1
}

main () {
  local confirm username timezone locale

  read -r -p "Do you want to provision the current image. This may cause data loss (y/N)? " confirm

  if ! [[ "$confirm" == [Yy]* ]]; then
    fatal "Aborting provisioning"
  fi

  read -r -p "Your username: " username

  if ! [ "$username" ]; then
    fatal "Username is required"
  fi

  read -r -p "Your timezone (Default: $DEFAULT_TIMEZONE): " timezone
  read -r -p "Your locale (Default: $DEFAULT_LOCALE): " locale

  timezone="${timezone:-$DEFAULT_TIMEZONE}"
  locale="${locale:-$DEFAULT_LOCALE}"

  # Install packages.
  apt update || fatal "Unable to update apt repositories"
  apt install -y \
    locales \
    tzdata \
    ca-certificates \
    curl || fatal "Unable to install apt packages"

  # Configure locales.
  locale-gen "$locale" || fatal "Unable to generate locale"
  update-locale LANG="$locale"|| fatal "Unable to update locale"

  if ! [ -e "/usr/share/zoneinfo/$timezone" ]; then
    fatal "Invalid timezone given, timezone is not supported"
  fi

  ln -sf "/usr/share/zoneinfo/$timezone" /etc/localtime || fatal "Unable to symlink timezone to localtime"

  # Create user.
  adduser "$username" || fatal "Unable to create user"
  usermod -aG sudo "$username" || fatal "Unable to give user sudo"

  # Configure WSL.
cat <<EOF > /etc/wsl.conf || fatal "Unable to create WSL config"
[user]
default=$username

[boot]
systemd=true

[network]
generateResolvConf=true

[interop]
enabled=true
appendWindowsPath=true
EOF
}

case "${1:-}" in
  -h|--help) usage ;;
  -v|--version) echo "$app_version" ;;
  *) main ;;
esac
