#!/usr/bin/env bash

app_name="${0##*/}"
app_version="0.0.0"

usage () {
  cat <<EOF
Download and SHA-256 checksum-validate a file.

The requested URL is validated against the given SHA-256 checksum before
the contents are returned. If the file does not match the checksum, the program
exits with error code 1.

If no sha-256 checksum argument is given, prints out the current checksum for
the requested URL to STDOUT.

If no output-file argument is given, but checksum is, the file contents
are printed to STDOUT, if they match the given checksum.

If url, output-file and sha-256 argument are all given, the file is saved as
the specified output-file, if the file matches the given checksum.

Usage:
  $ $app_name [options] <url> [output-file] [sha-256]

Options:
  -h, --help     Print this message
  -v, --version  Print version number

Examples:

  The following prints SHA-256 checksum for the requested document.csv file:

    $ $app_name https://example.tld/document.csv
    > ecf701f727d9e2d77c4aa49ac6fbbcc997278aca010bddeeb961c10cf54d435a

  The following would print document.csv contents to STDOUT, if it matches
  the given SHA-256 checksum:

    $ $app_name https://example.tld/document.csv \
      ecf701f727d9e2d77c4aa49ac6fbbcc997278aca010bddeeb961c10cf54d435a

  The following would download document.csv and save it as file.csv to the
  current working directory. Before saving, the file is validated against
  the given SHA-256 checksum:

    $ $app_name https://example.tld/document.csv file.csv \
      ecf701f727d9e2d77c4aa49ac6fbbcc997278aca010bddeeb961c10cf54d435a
EOF
}

main () {
  local url sha256 checksum file status temporary directory basename

  url="${1:-}"
  status=0

  if [ "$#" -eq 2 ]; then
    file=""
    sha256="${2:-}"
  else
    file="${2:-}"
    sha256="${3:-}"
  fi

  if [ "$file" ]; then
    directory="$(dirname "$file")"
    basename="$(basename "$file")"
    temporary="${directory:-.}/.cc-${basename}.tmp"
  else
    temporary="$(mktemp)"
  fi

  if ! [ "$url" ]; then
    echo "URL is required." >&2
    exit 1
  fi

  curl -qfSL --progress-bar --output "$temporary" -- "$url" || exit 1

  checksum="$(shasum -a 256 -- "$temporary" | awk '{print $1}')" || status=1

  if [ "$status" -eq 1 ]; then
    rm "$temporary"
    exit 1
  fi

  if ! [ "$sha256" ]; then
    echo "SHA-256: $checksum"
    rm "$temporary" || exit 1
    exit 0
  fi

  if [ "$checksum" = "$sha256" ]; then
    if [ "$file" ]; then
      mv "$temporary" "$file" || exit 1
    else
      cat "$temporary" || exit 1
    fi

    exit 0
  fi

  echo "SHA-256 checksum mismatch." >&2
  echo "⋯ Expected: $sha256" >&2
  echo "⋯ Received: $checksum" >&2
  rm "$temporary" || exit 1
  exit 1
}

case "${1:-}" in
  ""|-h|--help) usage ;;
  -v|--version) echo "$app_version" ;;
  *) main "$@" ;;
esac
