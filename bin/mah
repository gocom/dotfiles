#!/usr/bin/env bash

app_name="${0##*/}"
app_version="0.0.0"

MAH_HOME="${MAH_HOME:-$HOME/.mah}"

usage () {
  cat <<EOF
View man pages in a \$BROWSER.

Generates HTML document from the specified manpage using mandoc, and opens it
using the configured \$BROWSER. Generated pages are saved to \$MAH_HOME
directory to avoid having to generate HTML document again for once accessed
manpage.

Generated HTML document can be styled with CSS by placing css file
to \$MAH_HOME/style.css, defaulting to ~/.mah/style.css, if \$MAH_HOME
is not set.

Usage:
  $ $app_name [options] [page ...]

Options:
  -h, --help     Print this message
  -v, --version  Print version number
  -f, --force    Overwrite cached page

Example:
  $ $app_name bash

Environment:

  BROWSER
    Web browser the HTML formatted man page is opened in. The man page URL is
    passed to the configured command as the first appended argument.
    Current value: $BROWSER

  MAH_HOME
    Directory where $app_name stores generated and cached HTML pages, and it's
    configuration options.
    Current value: $MAH_HOME
EOF
}

fatal () {
  echo "$1" >&2
  exit 1
}

depends () {
  local name abort

  abort=0

  for name in "basename" "cat" "dirname" "gunzip" "man" "mandoc" "mkdir"; do
    if ! [ "$(command -v "$name")" ]; then
      echo "Dependency missing: $name" >&2
      abort=1
    fi
  done

  if ! [ "$BROWSER" ]; then
    echo "BROWSER environment variable is not set." >&2
    abort=1
  fi

  if [ "$abort" -eq 1 ]; then
    fatal "Some dependencies not met, aborting."
  fi
}

main () {
  local status option force args OPTIND OPTARG OPTERR

  args=()
  status=0

  for option in "$@"; do
    case "$option" in
      -*) break ;;
      *) args+=("$option"); shift ;;
    esac
  done

  while getopts ":hvfu-:" option; do
    case "$option" in
      -)
        case "$OPTARG" in
          help) usage; exit 0 ;;
          version) echo "$app_version"; exit 0 ;;
          force) force=1 ;;
          *)
            if [ "$OPTERR" = 1 ] ; then
              fatal "Unknown option --$OPTARG"
            fi
            ;;
        esac;;
      h) usage; exit 0 ;;
      v) echo "$app_version"; exit 0 ;;
      f) force=1 ;;
      \?) fatal "Invalid option: -$OPTARG" ;;
      :) fatal "Option -$OPTARG requires an argument." ;;
      *) fatal "Unexpected: -$OPTARG" ;;
    esac
  done

  shift "$((OPTIND - 1))"
  set -- "${args[@]}" "$@"

  depends

  for option in "$@"; do
    html "$option" || status=1
  done

  return "$status"
}

open-page () {
  local path

  path="$1"

  if [ "$(command -v wslpath)" ]; then
    path="$(wslpath -aw "$1")"
  fi

  $BROWSER "file://$path"
}

html () {
  local page man path directory basename css head html

  page="${1:-}" || return 0
  path="$(man -w "$page")" || return 1

  if ! [ "$path" ] || ! [ -r "$path" ]; then
    echo "'$page' does not exist." >&2
    return 1
  fi

  directory="$MAH_HOME/cache/$(basename "$(dirname "$path")")"
  basename="$(basename "$path")"
  man="$directory/$basename.html"

  if ! [ "$force" ] && [ -e "$man" ]; then
    open-page "$man" || return 1
    return 0
  fi

  mkdir -p "$directory" || return 1

  case "$path" in
    *.gz) gunzip --to-stdout "$path" | mandoc -Oman='../man%S/%N.%S.html' -Thtml > "$man" ;;
    *) mandoc -Oman='../man%S/%N.%S.html' -Thtml < "$path" > "$man" ;;
  esac

  if [ -e "$MAH_HOME/style.css" ]; then
    css="$(cat "$MAH_HOME/style.css")" || return 1

    read -r -d '' head <<EOF
<style>
$css
</style>
EOF

    html="$(cat "$man")" || return 1
    html="${html//<\/head>/$head<\/head>}"
    echo "$html" > "$man" || return 1
  fi

  open-page "$man" || return 1
}

main "$@"
