#!/usr/bin/env bash

app_name="${0##*/}"
app_version="0.0.0"

if [ "${WGET_COOKIES:-}" ]; then
  cookies="$WGET_COOKIES"
else
  cookies="$HOME/.wget-cookies"
fi

if ! [ -e "$cookies" ]; then
  touch "$cookies"
fi

usage () {
  cat <<EOF
Download files using wget.

Usage:
  $ $app_name [options] [command] <url>

Options:
  -h, --help     Print this message
  -v, --version  Print version number

Commands:
  $ $app_name auth
  Prompt for username and password, download a file using basic HTTP
  authentication.

  $ $app_name download
  Download files. Prompts for list of URLs, which are saved into
  temporary '.wget-urls' file in the current working directory.
  If '.wget-urls' already exists, downloads are resumed from it.
  Downloaded files are saved into the current working directory.

  $ $app_name login <url[?<post-data>]>
  Establish a login session and store cookies in \$WGET_COOKIES.

Login:
  The post-data can use '{u}' and '{p}' variables that are substituted with
  prompted username and password, hiding them from terminal history. Retrieved
  cookies are stored in ~/.wget-cookies or \$WGET_COOKIES, if set.

Example:
  $ $app_name login "https://localhost/login?user={u}&pass={p}"
  $ $app_name auth
  $ $app_name download
EOF
}

download () {
  local status urls confirm temporary

  urls=".wget-urls"

  if [ -e "$urls" ]; then
    read -r -p "Use found '$urls' file (Yes/no)? " confirm

    case "$confirm" in
      Y*|y*)
        echo "Downloading URLs from '$urls' file..." >&2
      ;;
      *)
        echo "Aborting. Remove or rename '$urls' file, if you want to download to this". >&2
        echo "directory." >&2
        return 1
        ;;
    esac
  else
    temporary="$(mktemp --suffix=.wget-urls)" || return 1

    cat <<EOF > "$temporary" || return 1


# Please enter a list of URLs to download, one URL per line. Lines starting
# with '#' or whitespace will be ignored. Save and close the document to start
# the downloads. Leaving the document empty aborts downloading.
EOF

    nano "$temporary" || return 1
    awk '/^[^\s#]/' "$temporary" > "$urls" || return 1
    rm -f "$temporary" || return 1
  fi

  awk '/^[^\s#]/' "$urls" | wget \
    --no-clobber \
    --adjust-extension \
    --load-cookies="$cookies" \
    --max-redirect=30 \
    --no-verbose \
    --quiet \
    --random-wait \
    --referer="${*:$#}" \
    --show-progress \
    --tries=3 \
    --wait=3 \
    --waitretry=15 \
    -i - || status="$?"

  rm -f "$urls"
  return "${status:-0}"
}

auth () {
  local username password
  read -r -p "Username: " username
  read -r -s -p "Password: " password
  download --http-user="$username" --http-password="$password" "$@"
}

login () {
  local param query url data username password

  query="${*:$#}"
  url="${query%%\?*}"
  data="${query:((${#url}+1))}"

  if ! [ "$data" ] || [[ "$data" =~ "{u}" ]]; then
    read -r -p "Username: " username
    param="$(perl -MURI::Escape -e 'print uri_escape($ARGV[0]);' "$username")"
    data="${data/\{u\}/"$param"}"
  fi

  if ! [ "$data" ] || [[ "$data" =~ "{p}" ]]; then
    read -r -s -p "Password: " password
    param="$(perl -MURI::Escape -e 'print uri_escape($ARGV[0]);' "$password")"
    data="${data/\{p\}/"$param"}"
  fi

  exec wget \
    --http-user="$username" \
    --http-password="$password" \
    --keep-session-cookies \
    --load-cookies="$cookies" \
    --max-redirect=30 \
    --no-cache \
    --output-document=- \
    --referer="$url" \
    --save-cookies="$cookies" \
    --post-data="$data" \
    --quiet \
    --tries=1 \
    "$@" > /dev/null
}

case "${1:-}" in
  -h|--help) usage ;;
  -v|--version) echo "$app_version" ;;
  auth) auth "${@:2}" ;;
  login) login "${@:2}" ;;
  download) download "${@:2}" ;;
  *"{u}"*|*"{p}"*) login "$@" ;;
  *) download "$@" ;;
esac
