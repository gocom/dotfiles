#!/usr/bin/env bash

app_name="${0##*/}"
app_version="0.0.0"

usage () {
  cat <<EOF
Install and manage dotfiles.

Usage: $app_name [options] [command]

Options:
  -h, --help      Print this message
  -v, --version   Print version number
  -D, --dry-run   Dry-run without writing
  -S, --silent    Silent mode
  -V, --verbose   Verbose mode
      --color     Enable colors
      --no-color  Disable colors

  -d <filename>, --directory[=]<filename>
  Path to the dotfiles directory.

Commands:
  $app_name docs [filename ...]
  Generate documentation.

  $app_name dump
  Dumps dependencies to lockfiles.

  $app_name install
  Install dotfiles to the user's home directory.

  $app_name install-deps
  Install third-party dependencies through package managers.

  $app_name install-packages
  Install packages.

  $app_name lint
  Lint codebase.

  $app_name prefix
  Print dotfiles install path.

  $app_name pull
  Pull dotfiles from remote.

  $app_name test
  Run test suite.

  $app_name unit
  Run unit tests.

  $app_name version
  Prints dotfiles version number.

  $app_name watch
  Watch for file changes.

Examples:
  $app_name install absolute/path/to/dotfiles
EOF
}

prefix () {
  echo "$physical"
}

main () {
  local args OPTIND OPTARG OPTERR option options \
    color directory dryrun force silent verbose prefix physical \
    reset red green yellow blue magenta cyan cmd

  args=()

  for option in "$@"; do
    case "$option" in
      -*) break ;;
      *) args+=("$option"); shift ;;
    esac
  done

  color=1

  if [ "${TERM:-}" = "dumb" ] || [ "${NO_COLOR:-}" ]; then
    color=""
  fi

  while getopts ":hvVFDQSd:-:" option; do
    case "$option" in
      -)
        case "$OPTARG" in
          help) usage; exit 0 ;;
          version) echo "$app_version"; exit 0 ;;
          color) color=1 ;;
          directory) directory="${!OPTIND}"; OPTIND=$((OPTIND + 1)) ;;
          directory=*) directory="${OPTARG#*=}" ;;
          dryrun|dry-run) dryrun=1 ;;
          no-color) color="" ;;
          force) force=1 ;;
          verbose) verbose=1 ;;
          quiet|silent) silent=1 ;;
          *) fatal "Invalid option: --$OPTARG" ;;
        esac;;
      h) usage; exit 0 ;;
      v) echo "$app_version"; exit 0 ;;
      d) directory="$OPTARG" ;;
      D) dryrun=1 ;;
      F) force=1 ;;
      Q|S) silent=1 ;;
      V) verbose=1 ;;
      \?) fatal "Invalid option: -$OPTARG" ;;
      :) fatal "Option -$OPTARG requires an argument." ;;
      *) fatal "Unexpected: -$OPTARG" ;;
    esac
  done

  shift "$((OPTIND - 1))"
  set -- "${args[@]}" "$@"

  cmd="${1:-}"
  shift

  if [ "$color" ]; then
    reset="$(tput sgr0)"
    red="$(tput setaf 1)"
    green="$(tput setaf 2)"
    yellow="$(tput setaf 3)"
    blue="$(tput setaf 4)"
    magenta="$(tput setaf 5)"
    cyan="$(tput setaf 6)"
  fi

  if [ "$dryrun" ]; then
    log "${blue}â„¹${reset} Running with ${yellow}--dry-run${reset}, nothing will be written."
  fi

  if [ "${XDG_CONFIG_HOME:-}" ]; then
    prefix="$XDG_CONFIG_HOME/dotfiles"
  else
    prefix="$HOME/.dotfiles"
  fi

  if [ -h "$prefix" ]; then
    physical="$(readlink "$prefix")"
  else
    physical="$prefix"
  fi

  if [ "$directory" ] && ! valid "$directory/home/.bashrc"; then
    fatal "${red}âœ˜${reset} Given directory ${yellow}$directory${reset} does not contain dotfiles."
  fi

  if ! [ "$directory" ]; then
    options=()

    if [ "${DOTFILES_HOME:-}" ]; then
      options+=("$DOTFILES_HOME")
    fi

    if [ "${XDG_CONFIG_HOME:-}" ]; then
      options+=("$XDG_CONFIG_HOME/dotfiles")
    fi

    options+=("$HOME/.config/dotfiles")
    options+=("$HOME/.local/dotfiles")
    options+=("$HOME/.dotfiles")
    options+=("$PWD")

    verbose "${blue}â„¹${reset} Searching dotfiles directory location variants." \
      "${blue}â„¹${reset} Use ${yellow}-d /path/to${reset} if you want to manually set one."

    for option in "${options[@]}"; do
      verbose "${magenta}Â·${reset} $option"
    done

    for option in "${options[@]}"; do
      valid "$option" && directory="$option" && break
    done
  fi

  if ! [ "$directory" ]; then
    fatal "${red}âœ˜${reset} Could not find dotfiles directory."
  fi

  cd "$directory" || fatal "${red}âœ˜${reset} Could not change working directory to ${yellow}$directory${reset}."
  verbose "${blue}â„¹${reset} Using ${yellow}$directory${reset} as the directory."

  unique="$(date +"%s")"

  case "$cmd" in
    build) build ;;
    docs) docs "$@" ;;
    dump) dump ;;
    install) install ;;
    install-packages) install_packages ;;
    lint) lint ;;
    package) package ;;
    pull) pull ;;
    prefix) prefix ;;
    test) suite ;;
    unit) unit ;;
    version) version ;;
    watch) watch "$@" ;;
    *) usage ;;
  esac
}

build () {
  install_packages || return 1
  docs || return 1
}

# Install script.

install () {
  local line

  chmod +x bin/*

  base "$directory"

  while read -r line; do
    if [ "$line" ]; then
      link "$line"
    fi
  done < "$directory/.dotfile-links"

  while read -r line; do
    if [ "$line" ]; then
      copy "$line"
    fi
  done < "$directory/.dotfile-copy"

  log "${green}âœ“${reset} Dotfiles linked"
}

install_packages () {
  local line name checksum url current_checksum download package meta file

  while read -r line; do
    if ! [ "$line" ]; then
      continue
    fi

    name="$(echo "$line" | cut -d' ' -f1)"
    checksum="$(echo "$line" | cut -d' ' -f2)"
    url="$(echo "$line" | cut -d' ' -f3)"
    file="__download.zip"
    download="packages/$name/$file"
    package="packages/$name"
    meta="packages/$name.meta"

    if ! [ "$url" ]; then
      continue
    fi

    if [ -e "$meta" ]; then
      current_checksum="$(cut -d' ' -f2 < "$meta")"

      if [ "$checksum" = "$current_checksum" ]; then
        log "${blue}â†¯${reset} Package ${yellow}$name${reset} is up-to-date"
        log "${blue}Â·${reset} Checksum: $current_checksum"
        continue
      fi
    fi

    log "${blue}â†¯${reset} Installing ${yellow}$name${reset} to ${yellow}$package${reset}..."
    log "${blue}Â·${reset} URL: $url"
    log "${blue}Â·${reset} Checksum: $checksum"

    rm -rf "$package" > /dev/null \
      || fatal "${red}âœ˜${reset} Failed to remove old ${yellow}$package${reset}"

    mkdir -p "$package" > /dev/null \
      || fatal "${red}âœ˜${reset} Failed to create directory ${yellow}$package${reset}"

    bin/curl-checksum "$url" "$download" "$checksum" \
      || fatal "${red}âœ˜${reset} Downloading file failed"

    cd "$package" > /dev/null \
      || fatal "${red}âœ˜${reset} Navigating to directory ${yellow}$package${reset} failed"

    unzip "$file" > /dev/null \
      || fatal "${red}âœ˜${reset} Extracting ${yellow}$package${reset} failed"

    rm "$file" > /dev/null \
      || fatal "${red}âœ˜${reset} Removing ${yellow}$package${reset} failed"

    cd ../.. > /dev/null \
      || fatal "${red}âœ˜${reset} Failed navigating back"

    echo "$line" > "$meta" \
      || fatal "${red}âœ˜${reset} Failed to create file ${yellow}$meta${reset}"
  done < "$directory/.dotfile-packages"

  chmod +x packages/*/bin/*

  log "${green}âœ“${reset} Packages installed"
}

valid () {
  if [ -r "$1/home/.bashrc" ]; then
    return 0
  else
    return 1
  fi
}

base () {
  local path status relative

  path="${1:-}"

  if ! [ "$path" ] || ! [ -r "$path" ]; then
    fatal "'$path' is not a readable"
  fi

  relative="$(relpath "$prefix" "$HOME")"

  if [ "$path" = "$prefix" ] || [ "$path" = "$physical" ]; then
    log "${green}âœ“${reset} $relative"
    return 0
  fi

  backup "$path"

  if ! [ "$dryrun" ]; then
    ln -s "$path" "$prefix" || fatal "${yellow}âœ˜${reset} â€• unable to link"
  fi

  log "${blue}â†¯${reset} $prefix ${cyan}â‹¯${reset} $path"
}

msg () {
  local message

  for message in "$@"; do
    echo "$message"
  done
}

log () {
  if ! [ "$silent" ]; then
    msg "$@"
  fi
}

verbose () {
  if [ "$verbose" ]; then
    log "$@"
  fi
}

error () {
  log "$@" >&2
}

fatal () {
  error "$@"
  exit 1
}

relpath () {
  perl -e 'use File::Spec; print File::Spec->abs2rel(@ARGV) . "\n"' "$@"
  return "$?"
}

run () {
  if ! [ "$dryrun" ]; then
    "$1" "${@:2}" || return 1
  fi
}

link () {
  local name where origin directory parent path status current

  name="${1:-}"
  origin="$prefix/$name"
  where=""
  parent="${name%%/*}"
  path="${name#*/}"

  if ! [ "$name" ]; then
    fatal "Origin must be given for the link."
  fi

  if [ "$parent" = "$path" ]; then
    parent="home"
  fi

  case "$parent" in
    home) where="$HOME/$path" ;;
  esac

  if ! [ "$where" ]; then
    fatal "Origin directory does not have target mapping"
  fi

  directory="$(dirname -- "$where")"

  case "$origin" in
    "$HOME"*) origin="$(relpath "$origin" "$directory")" || return 1 ;;
  esac

  if [ -h "$where" ]; then
    current="$(readlink "$where")" || fatal "Unable to readlink '$where'"

    if [ "$current" = "$origin" ]; then
      log "${green}âœ“${reset} $path"
      verbose \
        "${magenta}Â·${reset} $where" \
        "${magenta}â†³${reset} $origin"
      return 0
    else
      log "${blue}â†·${reset} $path"
      verbose \
        "${magenta}Â·${reset} $where" \
        "${yellow}â€•${reset} $current" \
        "${magenta}â†³${reset} $where"
    fi
  fi

  if ! [ -e "$directory" ]; then
    log "${blue}â†³${reset} $directory"

    if ! [ "$dryrun" ]; then
      mkdir -p "$directory" || return 1
    fi
  fi

  backup "$where" || status=1

  if [ "$status" ] && ! [ "$force" ]; then
    error "${red}âœ˜${reset} $path ${yellow}â€•${reset} unable to backup"
    return 1
  fi

  if ! [ "$dryrun" ]; then
    ln -s "$origin" "$where" || status=1

    if [ "$status" ]; then
      error "${red}âœ˜${reset} $path ${yellow}â€•${reset} unable to link"
      verbose "${yellow}Â·${reset} $where" "${yellow}â†³${reset} $origin"
      return 1
    fi
  fi

  log "${blue}â†¯${reset} $path"
  verbose "${magenta}Â·${reset} $where" "${magenta}â†³${reset} $origin"
}

copy () {
  local name where origin directory parent path status current content

  name="${1:-}"
  origin="$prefix/$name"
  where=""
  parent="${name%%/*}"
  path="${name#*/}"

  if ! [ "$name" ]; then
    fatal "Origin must be given for the copy operation."
  fi

  if [ "$parent" = "$path" ]; then
    parent="home"
  fi

  case "$parent" in
    home) where="$HOME/$path" ;;
  esac

  if ! [ "$where" ]; then
    fatal "Origin directory does not have target mapping"
  fi

  directory="$(dirname -- "$where")"

  case "$origin" in
    "$HOME"*) origin="$(relpath "$origin" "$directory")" || return 1 ;;
  esac

  if [ -e "$where" ]; then
    current="$(cat "$where")" || fatal "Unable to read file '$where'"
    content="$(cat "$origin")" || fatal "Unable to read file '$origin'"

    if ! [ -h "$where" ] && [ "$current" = "$content" ]; then
      log "${green}âœ“${reset} $path"
      verbose \
        "${magenta}Â·${reset} $where" \
        "${magenta}â†³${reset} $origin"
      return 0
    else
      log "${blue}â†·${reset} $path"
      verbose \
        "${magenta}Â·${reset} $where" \
        "${yellow}â€•${reset} $current" \
        "${magenta}â†³${reset} $where"
    fi
  fi

  if ! [ -e "$directory" ]; then
    log "${blue}â†³${reset} $directory"

    if ! [ "$dryrun" ]; then
      mkdir -p "$directory" || return 1
    fi
  fi

  backup "$where" || status=1

  if [ "$status" ] && ! [ "$force" ]; then
    error "${red}âœ˜${reset} $path ${yellow}â€•${reset} unable to backup"
    return 1
  fi

  if ! [ "$dryrun" ]; then
    cat "$origin" > "$where" || status=1

    if [ "$status" ]; then
      error "${red}âœ˜${reset} $path ${yellow}â€•${reset} unable to copy"
      verbose "${yellow}Â·${reset} $where" "${yellow}â†³${reset} $origin"
      return 1
    fi
  fi

  log "${blue}â†¯${reset} $path"
  verbose "${magenta}Â·${reset} $where" "${magenta}â†³${reset} $origin"
}

backup () {
  local backup origin parent

  origin="${1:-}"

  if ! [ "$origin" ] || ! [ -e "$origin" ]; then
    return 0
  fi

  backup="backups/$unique/$origin"
  parent="$(dirname "$backup")"

  log "${magenta}â†º${reset} $origin ${yellow}â€•${reset} $backup"

  if ! [ "$dryrun" ]; then
    mkdir -p "$parent" || return 1
    mv "$origin" "$backup" || return 1
  fi
}

# Generate docs.

docs () {
  local f status docs

  status=0
  docs=()

  if [ "$#" -gt 0 ]; then
    for f in "$@"; do
      doc "$f" || status=1
    done

    return "$status"
  fi

  rm -rf share/man/man*/ || return 1

  for f in ./docs/man/*/*.ronn ./docs/man/*/*.md; do
    if [ -e "$f" ]; then
      doc "$f" || status=1
    fi
  done

  for f in ./bin/*; do
    if [ -e "$f" ]; then
      doc "$f" || status=1
    fi
  done

  if [ "$status" -eq 1 ]; then
    error "${yellow}âœ˜${reset} Not all man pages were created successfully"
    return 1
  fi

  log "${green}âœ“${reset} Man pages generated"
}

# Generate documentation from the given file.
#
# The file can be either a executable binary, or .md/.ronn document.

doc () {
  local c f d b o t c n format status option

  f="${1:-}"
  status=0

  if ! [ -e "$f" ]; then
    error "${yellow}âœ˜${reset} $f ${yellow}â€•${reset} not readable document"
    return 1
  fi

  d="$(basename "$(dirname "$f")")"
  n="$(basename "$f")"

  case "$n" in
    *.*.*) b="${n%.*}" ;;
    *.*) b="$n" ;;
    *) b="$n.1" ;;
  esac

  o="share/man/$d/$b"
  t="share/man/pandoc.html"
  c="../style.css"

  mkdir -p "share/man/$d" || return 1

  for option in "${docs[@]}"; do
    if [ "$option" = "$b" ]; then
      log "${blue}â‹¯${reset} $f ${blue}â€•${reset} skip already used"
      return 0
    fi
  done

  docs+=("$b")

  case "$f" in
    *.md) format="pandoc" ;;
    *.ronn) format="ronn" ;;
    *) format="help2man" ;;
  esac

  if [ "$format" = "ronn" ]; then
    ronn -r "$f" || status=1
  fi

  if [ "$format" = "pandoc" ]; then
    pandoc -s -f markdown -t man -o "$o" "$f" || status=1
    pandoc -s -f markdown -t html --toc \
      --template="$t" --css "$c" -o "$o.html" "$f" || status=1
  fi

  if [ "$format" = "help2man" ]; then
    if ! [ -f "$f" ] || ! [ -x "$f" ]; then
      log "${yellow}âœ˜${reset} $f ${yellow}â€•${reset} not executable"
      return 1
    fi

    help2man -N -S "dotfiles" -n "$n" -o "share/man/man1/$b" "$f" || status=1
  fi

  if [ "$status" -eq 1 ]; then
    log "${yellow}âœ˜${reset} $f ${yellow}â€•${reset} $format"
    return 1
  fi

  log "${green}âœ“${reset} $f ${green}â€•${reset} $format"
}

lint () {
  local f status bang code

  code=0

  for f in bin/* platform/*/bin/*; do
    if ! [ -f "$f" ]; then
      continue
    fi

    bang="$(head -n1 < "$f")"
    status=0

    case "$bang" in
      *sh) shellcheck "$f" || status=1 ;;
      *) log "${blue}â‹¯${reset} $f" ;;
    esac

    if [ "$status" -eq 0 ]; then
      log "${green}âœ“${reset} $f"
    else
      log "${red}âœ˜${reset} $f"
    fi

    if [ "$status" -gt "$code" ]; then
      code="$status"
    fi
  done

  return "$code"
}

unit () {
  bats test/
}

suite () {
  log "Lint â¬Ž"
  lint
  log "Unit â¬Ž"
  unit
}

watch () {
  if ! [ "$(command -v entr)" ]; then
    fatal "${red}âœ˜${reset} 'entr' not installed."
  fi

  if [ "${1:-}" = "run" ]; then
    lint
    docs
    return 0
  fi

  find bin/* platform/*/bin/* docs/* | entr dotfiles watch run
}

# Dump dependencies.

dump () {
  brew bundle dump --force 2> /dev/null
  return 0
}

pull () {
  git pull
}

version () {
  if [ -e "VERSION" ]; then
    cat "VERSION" 2> /dev/null && return 0
  fi

  if [ "$(command -v git)" ]; then
    git describe --tags --first-parent --abbrev=11 --long --dirty --always 2> /dev/null && return 0
  fi

  echo "dev"
  return 0
}

package() {
  local target version status

  target="dist/dotfiles.zip"
  version="$(version)"
  status=0

  mkdir -p dist || return 1

  rm -f dist/dotfiles.zip || return 1

  echo "$version" > VERSION || return 1

  zip --symlinks -r "$target" \
    bashrc.d/ \
    bin/ \
    docker/ \
    home/ \
    packages/ \
    platform/ \
    share/ \
    .editorconfig \
    Aptfile \
    Brewfile \
    CHANGELOG.md \
    docker-compose.yml \
    LICENSE \
    Makefile \
    README.md \
    VERSION || status=1

  rm -f VERSION || return 1

  if [ "$status" -eq 1 ]; then
    return 1
  fi

  log "${green}âœ“${reset} Packaged ${blue}$version${reset} to $target"
}

main "$@"
