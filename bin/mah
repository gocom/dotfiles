#!/usr/bin/env bash

app_name="${0##*/}"
app_version="0.0.0"
app_data_directory="$HOME/.mah"

usage () {
  cat <<EOF
View man pages in a \$BROWSER.

Usage:
  $ $app_name [options] [page ...]

Options:
  -h, --help     Print this message
  -v, --version  Print version number
  -f, --force    Overwrite cached page
  -u, --uri      Open as x-man-page scheme

Example:
  $ ${0##*/} bash test
EOF
}

main () {
  local status option force format args OPTIND OPTARG OPTERR

  args=()
  status=0

  for option in "$@"; do
    case "$option" in
      -*) break ;;
      *) args+=("$option"); shift ;;
    esac
  done

  while getopts ":hvfu-:" option; do
    case "$option" in
      -)
        case "$OPTARG" in
          help) usage; exit 0 ;;
          version) echo "$app_version"; exit 0 ;;
          force) force=1 ;;
          uri) format="uri" ;;
          *)
            if [ "$OPTERR" = 1 ] ; then
              echo "Unknown option --$OPTARG"
              exit 1
            fi
            ;;
        esac;;
      h) usage; exit 0 ;;
      v) echo "$app_version"; exit 0 ;;
      f) force=1 ;;
      u) format="uri" ;;
      \?) echo "Invalid option: -$OPTARG"; exit 1 ;;
      :) echo "Option -$OPTARG requires an argument."; exit 1 ;;
      *) echo "Unexpected: -$OPTARG"; exit 1 ;;
    esac
  done

  shift "$((OPTIND - 1))"
  set -- "${args[@]}" "$@"

  for option in "$@"; do
    "${format:-html}" "$option" || status=1
  done

  return "$status"
}

open-page () {
  local path

  path="$1"

  if [ "$(command -v wslpath)" ]; then
    path="$(wslpath -aw "$1")"
  fi

  $BROWSER "file://$path"
}

html () {
  local page man path generator directory basename css head html

  page="${1:-}" || return 0
  path="$(man -w "$page")" || return 1

  if ! [ "$path" ] || ! [ -r "$path" ]; then
    echo "'$page' does not exist." >&2
    return 1
  fi

  directory="$app_data_directory/$(basename "$(dirname "$path")")"
  basename="$(basename "$path")"
  man="$directory/$basename.html"

  if ! [ "$force" ] && [ -e "$man" ]; then
    open-page "$man" || return 1
    return 0
  fi

  mkdir -p "$directory" || return 1

  if [ "$(command -v mandoc)" ]; then
    generator="mandoc -Oman='../man%S/%N.%S.html'"
  else
    generator="groff -mandoc"
  fi

  case "$path" in
    *.gz) gunzip --to-stdout "$path" | $generator -Thtml > "$man" ;;
    *) $generator -Thtml < "$path" > "$man" ;;
  esac

  if [ -e "$app_data_directory/style.css" ]; then
    css="$(cat "$app_data_directory/style.css")" || return 1

    read -r -d '' head <<EOF
<style>
$css
</style>
EOF

    html="$(cat "$man")" || return 1
    html="${html//<\/head>/$head<\/head>}"
    echo "$html" > "$man" || return 1
  fi

  open-page "$man" || return 1
}

uri () {
  open "x-man-page://${1:-}"
}

main "$@"
